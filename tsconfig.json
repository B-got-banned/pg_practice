{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2024",
    "jsx": "react-jsx",
    "checkJs": false,
    "experimentalDecorators": false,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strict": true,
    "sourceMap": true,
    "outDir": "./dist"
  },
  "exclude": ["node_modules", "**/node_modules/*"],
  "include": ["**/*.ts"]
}
